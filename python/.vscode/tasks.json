{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "⚡ Fast Start 快速开始",
            "type": "shell",
            "command": "./scripts/fast_start.ps1"
        },
        // {
        //     "label": "🤖 Help 帮助：显示所有命令",
        //     "type": "shell",
        //     "command": "uv run scripts/small-git.py --help; uv run scripts/small-git.py zen"
        // },
        {
            "label": "🌏 Env 更新开发环境",
            "type": "shell",
            "command": "uv run scripts/small-git.py env"
        },
        {
            "label": "🗑️ Clean 清理日志",
            "type": "shell",
            "command": "uv run scripts/small-git.py clean"
        },
        // {
        //     "label": "🚓 Check 语法检查并格式化当前文件",
        //     "type": "shell",
        //     "command": "uv run scripts/small-git.py check ${file}"
        // },
        {
            "label": "🚓 Check 格式化和语法检查",
            "type": "shell",
            "command": "uv run scripts/small-git.py check",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "❗ Strict Check 严格检查",
            "type": "shell",
            "command": "uv run scripts/small-git.py check --strict",
        },
        {
            "label": "🔄️ Sync 同步远程分支",
            "type": "shell",
            "command": "uv run scripts/small-git.py sync"
        },
        {
            "label": "🌳 Rebase 变基：更新个人分支的基点",
            "type": "shell",
            "command": "uv run scripts/small-git.py rebase"
        },
        // {
        //     "label": "🔀 Merge 合并：提交 Merge Request 前的检查",
        //     "type": "shell",
        //     "command": "uv run scripts/small-git.py merge"
        // },
        {
            "label": "🪓 Reset 重置：保留当前代码，使个人分支回到基点",
            "type": "shell",
            "command": "uv run scripts/small-git.py reset"
        },
        {
            "label": "⏫ Force Push 强制推送：覆盖远程分支",
            "type": "shell",
            "command": "uv run scripts/small-git.py force-push"
        },
        {
            "label": "🔨 Squash 压缩：将个人分支上的所有提交压缩成一个",
            "type": "shell",
            "command": "uv run scripts/small-git.py squash"
        },
        // {
        //     "label": "🗄️ Stash 暂存",
        //     "type": "shell",
        //     "command": "uv run scripts/small-git.py stash"
        // },
        {
            "label": "📦 Submodule 恢复子模块",
            "type": "shell",
            "command": "uv run scripts/small-git.py submod"
        },
        // {
        //     "label": "📦 Submodule-Remote 更新子模块（到远程最新）",
        //     "type": "shell",
        //     "command": "uv run scripts/small-git.py submod --remote"
        // }
    ],
}
